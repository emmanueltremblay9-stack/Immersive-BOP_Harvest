{
  "policy": {
    "implementation": "Built-in NeoForge additive loot modifiers and generated subtables only.",
    "conditions": [
      "Correct BOP block loot table",
      "Required knife or sword tag",
      "No BOP shears",
      "No Silk Touch",
      "No Fortune scaling"
    ],
    "hand_harvest": "No additional drops.",
    "explosions": "No new drops because a matching tool is required."
  },
  "rules": [
    {
      "blocks": [
        "biomesoplenty:high_grass",
        "biomesoplenty:high_grass_plant"
      ],
      "tools_any": [
        "#c:tools/knife"
      ],
      "output": "farmersdelight:straw",
      "count": 1,
      "chance": 0.5,
      "state_condition": null,
      "notes": "One roll per destroyed segment. No Fortune scaling."
    },
    {
      "blocks": [
        "biomesoplenty:dune_grass",
        "biomesoplenty:desert_grass",
        "biomesoplenty:dead_grass",
        "biomesoplenty:sea_oats",
        "biomesoplenty:reed"
      ],
      "tools_any": [
        "#c:tools/knife"
      ],
      "output": "farmersdelight:straw",
      "count": 1,
      "chance": 0.5,
      "state_condition": null,
      "notes": "No hand-harvest bonus."
    },
    {
      "blocks": [
        "biomesoplenty:barley"
      ],
      "tools_any": [
        "#c:tools/knife"
      ],
      "output": "farmersdelight:straw",
      "count": 1,
      "chance": 0.5,
      "state_condition": {
        "half": "lower"
      },
      "notes": "Lower half only. Do not convert barley into wheat."
    },
    {
      "blocks": [
        "biomesoplenty:bush",
