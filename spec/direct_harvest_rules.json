      "chance": 0.5,
      "state_condition": null,
      "notes": "Small woody material."
    },
    {
      "blocks": [
        "biomesoplenty:bramble_leaves"
      ],
      "tools_any": [
        "#c:tools/knife"
      ],
      "output": "minecraft:stick",
      "count": 1,
      "chance": 0.25,
      "state_condition": null,
      "notes": "Low yield; leaves are not a reliable wood source."
    },
    {
      "blocks": [
        "biomesoplenty:glowworm_silk",
        "biomesoplenty:glowworm_silk_strand"
      ],
